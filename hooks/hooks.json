{
  "description": "Auto-capture conversations and inject wiki context at session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "UV_PROJECT_ENVIRONMENT=${HOME}/.local/share/lyt-assistant/.venv uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "UV_PROJECT_ENVIRONMENT=${HOME}/.local/share/lyt-assistant/.venv uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/scripts/session-end.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "UV_PROJECT_ENVIRONMENT=${HOME}/.local/share/lyt-assistant/.venv uv run --directory ${CLAUDE_PLUGIN_ROOT} python ${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
